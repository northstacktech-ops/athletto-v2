# ─── Supabase ─────────────────────────────────────────────────────────────────
# Deixe vazio (ou com placeholder) para rodar em modo mock/demo.
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_KEY=sua-anon-key-publica
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-secreta-apenas-no-server

# Management API (PAT da conta, sbp_...) — só para script npm run supabase:sync-auth (redirect URLs).
# Crie em: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=
# Opcional: sobrescreve o Site URL do Auth (ex.: https://app.meusite.com)
# SUPABASE_AUTH_SITE_URL=

# ─── Athletto: superadmin seed ────────────────────────────────────────────────
# Email do superadmin owner inicial — usado na primeira migration para popular
# a tabela `superadmins`. Pode ficar vazio em dev.
ATHLETTO_OWNER_EMAIL=

# ─── Cron (Vercel) ────────────────────────────────────────────────────────────
# Segredo do cron diário /api/cron/processar-notificacoes (gera lembretes de
# pagamento). Defina esta env no Vercel: o Vercel Cron envia automaticamente
# o header `Authorization: Bearer <CRON_SECRET>`. Se vazia, o endpoint roda
# sem checagem (apenas em dev).
CRON_SECRET=

# ─── ValidaPay ────────────────────────────────────────────────────────────────
VALIDAPAY_CLIENT_ID=
VALIDAPAY_CLIENT_SECRET=
# 'sandbox' ou 'production'
VALIDAPAY_ENV=sandbox
VALIDAPAY_MASTER_ACCOUNT=
# URL pública do webhook (ex.: https://app.athletto.com.br/api/webhooks/validapay)
VALIDAPAY_WEBHOOK_URL=
# Segredo opcional adicionado como ?s=<valor> na URL do webhook
VALIDAPAY_WEBHOOK_SECRET=

# ─── Observabilidade ──────────────────────────────────────────────────────────
SENTRY_DSN=
